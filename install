#!/usr/bin/env bash
# Lope installer — registers skills and commands in each AI CLI host's
# native command/skill directory using the format that host expects.
#
# Usage: ./install [--host claude|codex|gemini|opencode|cursor|vibe|all]
# Compatible with bash 3.2+ (stock macOS).

set -euo pipefail

LOPE_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$LOPE_DIR/skills"
COMMANDS_DIR="$LOPE_DIR/commands"

# Parse args (POSIX-compatible, no bash 4+ features)
HOST="all"
SKIP_NEXT=0
ARGS=("$@")
for i in "${!ARGS[@]}"; do
  if [ "$SKIP_NEXT" = "1" ]; then SKIP_NEXT=0; continue; fi
  arg="${ARGS[$i]}"
  case "$arg" in
    --host=*)
      HOST="${arg#--host=}"
      ;;
    --host)
      next_i=$((i + 1))
      if [ "$next_i" -lt "${#ARGS[@]}" ]; then
        HOST="${ARGS[$next_i]}"
        SKIP_NEXT=1
      fi
      ;;
    claude|codex|gemini|opencode|cursor|vibe|all)
      HOST="$arg"
      ;;
  esac
done

# Idempotent replace: remove whatever is at $target (symlink, dir, or file).
replace_target() {
  local target="$1"
  if [ -L "$target" ]; then rm -f "$target"
  elif [ -d "$target" ]; then rm -rf "$target"
  elif [ -e "$target" ]; then rm -f "$target"
  fi
}

# ─── Per-host install functions ────────────────────────────────

# Claude Code: skills/ dir, one subdir per skill containing SKILL.md
install_claude() {
  local dir="$HOME/.claude/skills"
  mkdir -p "$dir"
  for skill in "$SKILLS_DIR"/lope "$SKILLS_DIR"/lope-*/ "$SKILLS_DIR"/using-lope; do
    skill="${skill%/}"
    [ -d "$skill" ] || continue
    local target="$dir/$(basename "$skill")"
    replace_target "$target"
    ln -sf "$(cd "$skill" && pwd)" "$target"
    echo "  claude:   $target -> $skill"
  done
}

# Codex: skills/ dir for skill content; commands/ for slash commands.
# Modern Codex ALSO reads AGENTS.md so we rely on that + skills symlinks.
install_codex() {
  local dir="$HOME/.codex/skills"
  mkdir -p "$dir"
  for skill in "$SKILLS_DIR"/lope "$SKILLS_DIR"/lope-*/ "$SKILLS_DIR"/using-lope; do
    skill="${skill%/}"
    [ -d "$skill" ] || continue
    local target="$dir/$(basename "$skill")"
    replace_target "$target"
    ln -sf "$(cd "$skill" && pwd)" "$target"
    echo "  codex:    $target -> $skill"
  done
}

# Gemini CLI: commands/<namespace>/<command>.toml format.
# We write 3 TOML files under ~/.gemini/commands/lope/ so the user gets
# /lope:negotiate, /lope:execute, /lope:audit (Gemini's slash syntax).
install_gemini() {
  local dir="$HOME/.gemini/commands/lope"
  mkdir -p "$dir"
  for toml in "$COMMANDS_DIR"/lope/*.toml; do
    [ -f "$toml" ] || continue
    local target="$dir/$(basename "$toml")"
    replace_target "$target"
    ln -sf "$(cd "$(dirname "$toml")" && pwd)/$(basename "$toml")" "$target"
    echo "  gemini:   $target -> $toml"
  done
}

# OpenCode: ~/.config/opencode/commands/ (PLURAL — singular "command" is wrong)
# with flat markdown files that MUST have YAML frontmatter including `agent:`.
# We ship pre-authored wrapper files at commands/opencode/*.md that have the
# right frontmatter shape and delegate to `lope <mode>` via bash in their body.
install_opencode() {
  local dir="$HOME/.config/opencode/commands"
  mkdir -p "$dir"
  # Clean up v0.3.1 mistake (singular "command" dir) if it exists
  local stale="$HOME/.config/opencode/command"
  if [ -d "$stale" ]; then
    for f in "$stale"/lope*.md "$stale"/using-lope.md; do
      [ -e "$f" ] && rm -f "$f"
    done
  fi
  for md in "$COMMANDS_DIR"/opencode/*.md; do
    [ -f "$md" ] || continue
    local target="$dir/$(basename "$md")"
    replace_target "$target"
    ln -sf "$(cd "$(dirname "$md")" && pwd)/$(basename "$md")" "$target"
    echo "  opencode: $target -> $md"
  done
}

# Cursor: ~/.cursor/agents/ with flat markdown files.
install_cursor() {
  local dir="$HOME/.cursor/agents"
  mkdir -p "$dir"
  for skill in "$SKILLS_DIR"/lope "$SKILLS_DIR"/lope-*/ "$SKILLS_DIR"/using-lope; do
    skill="${skill%/}"
    [ -d "$skill" ] || continue
    local name="$(basename "$skill")"
    local src="$skill/SKILL.md"
    local target="$dir/$name.md"
    [ -f "$src" ] || continue
    replace_target "$target"
    ln -sf "$src" "$target"
    echo "  cursor:   $target -> $src"
  done
}

# Mistral Vibe: ~/.vibe/skills/ with standard SKILL.md directory format.
install_vibe() {
  local dir="$HOME/.vibe/skills"
  # Only install if vibe is actually on disk — never create ~/.vibe from scratch
  [ -d "$HOME/.vibe" ] || { echo "  vibe:     (skipped — ~/.vibe not present)"; return 0; }
  mkdir -p "$dir"
  for skill in "$SKILLS_DIR"/lope "$SKILLS_DIR"/lope-*/ "$SKILLS_DIR"/using-lope; do
    skill="${skill%/}"
    [ -d "$skill" ] || continue
    local target="$dir/$(basename "$skill")"
    replace_target "$target"
    ln -sf "$(cd "$skill" && pwd)" "$target"
    echo "  vibe:     $target -> $skill"
  done
}

install_host() {
  case "$1" in
    claude)   install_claude ;;
    codex)    install_codex ;;
    gemini)   install_gemini ;;
    opencode) install_opencode ;;
    cursor)   install_cursor ;;
    vibe)     install_vibe ;;
    *) echo "Unknown host: $1"; return 1 ;;
  esac
}

echo ""
echo "Lope v0.4.3 — Installing skills and commands"
echo "─────────────────────────────────────────────"
echo ""

if [ "$HOST" = "all" ]; then
  for h in claude codex gemini opencode cursor vibe; do
    install_host "$h" 2>/dev/null || echo "  $h:      (skipped — not detected)"
  done
else
  install_host "$HOST"
fi

echo ""
echo "Verifying lope engine..."
if python3 -c "import sys; sys.path.insert(0, '$LOPE_DIR'); import lope; print('  OK — lope v' + lope.__version__)" 2>/dev/null; then
  :
else
  echo "  WARNING: python3 import check failed"
  echo "  Make sure Python 3.9+ is installed: python3 --version"
fi
echo ""
echo "Slash commands by host (honest state — not every host supports user slash commands):"
echo "  Claude Code  /lope  /lope-negotiate  /lope-execute  /lope-audit  /lope-help"
echo "  Gemini CLI   /lope:negotiate  /lope:execute  /lope:audit  /lope:help"
echo "  OpenCode     /lope  /lope-negotiate  /lope-execute  /lope-audit  /lope-help"
echo "  Cursor       (unverified — skills written to ~/.cursor/agents/)"
echo ""
echo "Content-only hosts (skills loaded as context, invoke lope via natural language):"
echo "  Codex        skills at ~/.codex/skills/ — agent runs 'lope <mode>' via bash"
echo "  Vibe         skills at ~/.vibe/skills/  — agent runs 'lope <mode>' via bash"
echo ""
echo "For any host, 'lope docs' prints the complete reference — all flags, all domains,"
echo "troubleshooting, hard rules. Also available as /lope-help where slash commands work."
echo ""
echo "IMPORTANT: Restart your CLI to pick up the new slash commands —"
echo "every host caches its skill list at session start."
echo ""
echo "Next steps:"
echo "  1. Configure validators:  PYTHONPATH=$LOPE_DIR python3 -m lope configure"
echo "  2. Check status:          PYTHONPATH=$LOPE_DIR python3 -m lope status"
echo "  3. Alias for convenience: alias lope='PYTHONPATH=$LOPE_DIR python3 -m lope'"
echo ""
